{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "defaultMode": "acceptEdits",
  "env": {
    "GUAVA_BACKEND_ROOT": "${CLAUDE_PROJECT_DIR}/../guava-admin",
    "GUAVA_JAVA_FORMAT": "auto"
  },
  "permissions": {
    "additionalDirectories": [
      "~/.claude/plugins/cache/guava-tools",
      "~/.claude/plugins/marketplaces/guava-tools"
    ],
    "allow": [
      "Read(./**)",
      "Read(../context/**)",
      "Read(~/.claude/plugins/cache/guava-tools/**)",
      "Read(~/.claude/plugins/marketplaces/guava-tools/**)",
      "Edit(./**)",
      "Edit(../context/**)",
      "Write(./**)",
      "Write(../context/**)",
      "Glob",
      "Grep",
      "Bash(pnpm *)",
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(mvn *)",
      "Bash(google-java-format *)",
      "Bash(mkdir *)",
      "Bash(date *)",
      "Bash(echo *)",
      "Bash(chmod *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(touch *)",
      "Bash(bash *)",
      "Bash(jq *)",
      "Bash(python3 *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(sort *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git stash*)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(gh run *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Bash(curl *)",
      "Bash(git push*)",
      "Bash(git commit*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(rm -rf *)"
    ]
  },
  "includeCoAuthoredBy": true
}
